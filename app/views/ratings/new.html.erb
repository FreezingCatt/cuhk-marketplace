<h1>Submit Rating</h1>

<%= form_with(model: @rating, local: true) do |form| %>
  <% if @rating.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(@rating.errors.count, "error") %> prohibited this rating from being saved:</h2>
      <ul>
        <% @rating.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= form.label :ratee_id, 'Rate User:' %>
    <% if @ratee %>
      <%= form.hidden_field :ratee_id, value: @ratee.id %>
      <p class="form-control-static"><%= @ratee.email %></p>
    <% else %>
      <%= form.select :ratee_id, User.all.where.not(id: current_user.id).map { |u| [u.email, u.id] }, { prompt: 'Select a user' }, class: 'form-control' %>
    <% end %>
  </div>

  <div class="form-group">
    <%= form.label :score, 'Score:' %>
    <%= form.select :score, 1..5, { prompt: 'Select a score' }, class: 'form-control' %>
  </div>

  <div class="form-group">
    <%= form.label :comment, 'Comment:' %>
    <%= form.text_area :comment, rows: 4, class: 'form-control' %>
  </div>

  <div class="actions">
    <%= form.submit 'Submit Rating', class: 'btn btn-primary' %>
    <%= link_to 'Cancel', root_path, class: 'btn btn-secondary' %>
  </div>
<% end %>
