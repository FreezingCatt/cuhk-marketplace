<h1>Message Details</h1>

<div class="card">
  <div class="card-header">
    <h4>
      <% if @message.sender == current_user %>
        To: <%= @message.receiver.email %>
      <% else %>
        From: <%= @message.sender.email %>
      <% end %>
    </h4>
  </div>
  <div class="card-body">
    <p class="card-text"><%= @message.content %></p>
  </div>
  <div class="card-footer text-muted">
    Sent: <%= @message.created_at.strftime('%Y-%m-%d %H:%M') %>
    <% if @message.read_at %>
      <br>Read: <%= @message.read_at.strftime('%Y-%m-%d %H:%M') %>
    <% end %>
  </div>
</div>

<div class="mt-3">
  <%= link_to 'Reply', new_message_path(receiver_id: @message.sender_id), class: 'btn btn-primary' %>
  <%= link_to 'Back to Messages', messages_path, class: 'btn btn-secondary' %>
</div>
