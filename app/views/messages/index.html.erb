<h1>Messages</h1>

<div class="row">
  <div class="col-md-6">
    <h2>Received Messages</h2>
    <% if @received_messages.empty? %>
      <p>No received messages yet.</p>
    <% else %>
      <ul class="list-group">
        <% @received_messages.each do |message| %>
          <li class="list-group-item <%= 'list-group-item-info' if message.read_at.nil? %>">
            <h4 class="list-group-item-heading">
              From: <%= message.sender.email %>
              <%= '(Unread)' if message.read_at.nil? %>
            </h4>
            <p class="list-group-item-text"><%= truncate(message.content, length: 50) %></p>
            <p class="text-muted"><%= message.created_at.strftime('%Y-%m-%d %H:%M') %></p>
            <%= link_to 'View', message_path(message), class: 'btn btn-sm btn-primary' %>
          </li>
        <% end %>
      </ul>
    <% end %>
  </div>
  
  <div class="col-md-6">
    <h2>Sent Messages</h2>
    <% if @sent_messages.empty? %>
      <p>No sent messages yet.</p>
    <% else %>
      <ul class="list-group">
        <% @sent_messages.each do |message| %>
          <li class="list-group-item">
            <h4 class="list-group-item-heading">To: <%= message.receiver.email %></h4>
            <p class="list-group-item-text"><%= truncate(message.content, length: 50) %></p>
            <p class="text-muted"><%= message.created_at.strftime('%Y-%m-%d %H:%M') %></p>
            <%= link_to 'View', message_path(message), class: 'btn btn-sm btn-primary' %>
          </li>
        <% end %>
      </ul>
    <% end %>
  </div>
</div>

<%= link_to 'New Message', new_message_path, class: 'btn btn-primary mt-3' %>
