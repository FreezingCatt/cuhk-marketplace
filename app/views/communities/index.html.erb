<div class="communities-container">
  <h1>Trading Communities</h1>

  <div class="community-actions">
    <% if user_signed_in? %>
      <%= link_to "Create Community", new_community_path, class: "btn btn-primary" %>
    <% end %>
  </div>

  <div class="communities-grid">
    <% @communities.each do |community| %>
      <div class="community-card">
        <h3><%= link_to community.name, community %></h3>
        <p class="community-description"><%= community.description %></p>
        <p class="community-rules"><%= truncate(community.rules, length: 100) if community.rules %></p>
        <div class="community-meta">
          <span class="member-count"><%= community.members.count %> members</span>
        </div>
      </div>
    <% end %>
  </div>

  <%= paginate @communities %>
</div>
