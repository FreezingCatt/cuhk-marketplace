<div class="community-form">
  <h1><%= @community.new_record? ? "Create New Community" : "Edit Community" %></h1>

  <%= form_with model: @community, local: true do |f| %>
    <% if @community.errors.any? %>
      <div class="error-messages">
        <h2><%= pluralize(@community.errors.count, "error") %> prohibited this community from being saved:</h2>
        <ul>
          <% @community.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="form-group">
      <%= f.label :name %>
      <%= f.text_field :name, required: true %>
    </div>

    <div class="form-group">
      <%= f.label :description %>
      <%= f.text_area :description, required: true, rows: 3 %>
    </div>

    <div class="form-group">
      <%= f.label :rules %>
      <%= f.text_area :rules, rows: 5, placeholder: "Community trading rules and guidelines..." %>
    </div>

    <div class="form-group">
      <%= f.check_box :is_public %>
      <%= f.label :is_public, "Public Community" %>
    </div>

    <div class="form-actions">
      <%= f.submit @community.new_record? ? "Create Community" : "Update Community", class: "btn btn-primary" %>
      <%= link_to "Cancel", communities_path, class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>
